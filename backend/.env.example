# Copy to .env and fill in values
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
H2H_CACHE_TTL_SECONDS=21600

# API key from resend.com - free tier works with onboarding@resend.dev as sender
RESEND_API_KEY=re_placeholder_replace_me
# Destination inbox for contact form submissions
CONTACT_EMAIL=you@example.com
