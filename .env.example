# Chicane.ai — environment variable template
# Copy to .env and fill in values. Never commit .env.

# ── General ───────────────────────────────────────────────────────────────────

# Runtime environment: development | production | test
APP_ENV=development

# ── Backend (FastAPI / uvicorn) ───────────────────────────────────────────────

# Host interface uvicorn binds to (0.0.0.0 to accept external connections)
BACKEND_HOST=127.0.0.1

# TCP port the FastAPI server listens on
BACKEND_PORT=8000

# Comma-separated list of frontend origins allowed by the CORS middleware
CORS_ORIGINS=http://localhost:5173

# Filesystem path used by FastF1 for its HTTP response cache
FASTF1_CACHE_DIR=./cache

# ── Frontend (Vite / React) ───────────────────────────────────────────────────

# Base URL of the FastAPI backend; must be reachable from the browser
VITE_API_BASE_URL=http://localhost:8000
